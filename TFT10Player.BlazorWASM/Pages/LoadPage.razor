@page "/Load"
@implements IDisposable
@inject NavigationManager Navigator
@inject AudioCachingService AudioCaching
@inject DownloadProgressService DownloadProgress
@code
{
    protected override void OnInitialized()
    {
        DownloadProgress.RenderMethod += RenderComponent;
        AudioCaching.InformAboutDownloadingFiles += OnInformAboutDownloadingFiles;
    }
    protected override void OnAfterRender(bool first_render)
    {
        if(first_render is false)
        {
            return;
        }
        _ = StartDownloading();
    }
}
@code
{
    public void Dispose()
    {
        DownloadProgress.RenderMethod -= RenderComponent;
        AudioCaching.InformAboutDownloadingFiles -= OnInformAboutDownloadingFiles;
    }
}

<div class="w-screen min-h-screen bg-[url('/assets/images/start-bg.jpg')] bg-cover bg-no-repeat relative flex flex-col items-center">
    <audio autoplay loop preload="auto" class="hidden">
        <source src="/assets/audio/load-page-bg.ogg" type="audio/ogg" />
    </audio>
    <div class="pointer-events-none absolute inset-0 flex items-start justify-center pt-1">
        <div class="pointer-events-auto w-11/12 max-w-[80%]">
            <div class="rounded-lg bg-gray-800/95 p-4">
                <div class="h-4 w-full overflow-hidden rounded bg-gray-700">
                    <div class="h-full bg-green-800" style="width: @(ProgressPercent)%"></div>
                </div>
                <div class="mt-2 text-center text-sm text-white">@(CustomProgressText ?? ProgressText)</div>
            </div>
        </div>
    </div>
</div>
<ModalDialog Visible=@ModalVisible VisibleChanged=@OnModalVisibleChanged Title=@ModalTitle Message=@ModalMessage PrimaryText=@ModalPrimaryText PrimaryClicked=@OnModalPrimary />

@code
{
    private bool ModalVisible { get; set; } = false;
    private string ModalPrimaryText { get; set; } = "Ok";
    private string ModalTitle { get; set; } = string.Empty;
    private string? CustomProgressText { get; set; } = null;
    private string ModalMessage { get; set; } = string.Empty;
    private TaskCompletionSource<bool>? ModalTaskSource { get; set; }
    private int ProgressPercent
    {
        get => DownloadProgress.Count > 0 ? (int)(DownloadProgress.Index * 100 / DownloadProgress.Count) : 0;
    }
    private string ProgressText
    {
        get => $"{DownloadProgress.Action} {DownloadProgress.Index + 1}/{DownloadProgress.Count}{(string.IsNullOrEmpty(DownloadProgress.FilePath) ? string.Empty : $" - {DownloadProgress.FilePath}")}{(DownloadProgress.Retry ? " (retry)" : string.Empty)}";
    }

    private void RenderComponent()
    {
        InvokeAsync(StateHasChanged);
    }
    private void ShowModal(bool value)
    {
        ModalVisible = value;
    }
    private async Task<bool> ShowModalAndWaitAsync(string title, string message, string primary_text)
    {
        ModalTitle = title;
        ModalMessage = message;
        ModalPrimaryText = primary_text;
        ModalTaskSource = new TaskCompletionSource<bool>(TaskCreationOptions.RunContinuationsAsynchronously);
        ModalVisible = true;
        await InvokeAsync(StateHasChanged);
        bool result = await ModalTaskSource.Task;
        ModalTaskSource = null;
        return result;
    }
    private async Task StartDownloading()
    {
        bool ok;
        try
        {
            CustomProgressText = "Starting...";
            _ = InvokeAsync(StateHasChanged);
            await Task.Delay(2000);
            CustomProgressText = null;
            ok = await AudioCaching.DownloadTracks();
        }
        catch
        {
            ok = false;
        }
        if(ok is false)
        {
            bool retry = await ShowModalAndWaitAsync(
                title: "Download failed",
                message: "Downloading files failed. Press Retry to try again or close this dialog to stop",
                primary_text: "Retry"
            );
            if(retry is true)
            {
                await StartDownloading();
            }
            else
            {
                Navigator.NavigateTo("about:blank", forceLoad: true);
            }
        }
        else
        {
            CustomProgressText = "Finished. Redirecting to the main page...";
            _ = InvokeAsync(StateHasChanged);
            await Task.Delay(2000);
            Navigator.NavigateTo("/Main", forceLoad: false);
        }
    }
    private async Task OnModalVisibleChanged(bool visible)
    {
        ModalVisible = visible;
        if(ModalVisible is false && ModalTaskSource is not null && ModalTaskSource.Task.IsCompleted is false)
        {
            ModalTaskSource.TrySetResult(false);
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task OnModalPrimary()
    {
        if(ModalTaskSource is not null && ModalTaskSource.Task.IsCompleted is false)
        {
            ModalTaskSource.TrySetResult(true);
        }
        ModalVisible = false;
        await InvokeAsync(StateHasChanged);
    }
    private async Task OnInformAboutDownloadingFiles()
    {
        bool accepted = await ShowModalAndWaitAsync(
            title: "Download required files",
            message: "This application needs to download audio files into your browser storage (OPFS). Continue? If you do not want this, the app will exit",
            primary_text: "Continue"
        );
        if(accepted is false)
        {
            Navigator.NavigateTo("about:blank", forceLoad: true);
            return;
        }
    }
}