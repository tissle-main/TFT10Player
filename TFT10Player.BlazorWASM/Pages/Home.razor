@page "/"
@implements IAsyncDisposable
@inject FileSystemService FS
@code
{
    protected override async Task OnInitializedAsync()
    {
        ImgUrl = await FS.GetUrlAsync("tft10player/imgs/start-bg.jpg");
    }
}

<PageTitle>Home</PageTitle>
<img src=@ImgUrl />

@code
{
    #region Instance
    private string ImgUrl { get; set; } = "";
    #endregion

    #region IAsyncDisposable
    public async ValueTask DisposeAsync()
    {
        await FS.RemoveUrlAsync("tft10player/StartBG.jpg");
    }
    #endregion
}