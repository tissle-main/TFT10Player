@code
{
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? PrimaryButton { get; set; }
    [Parameter] public RenderFragment? SecondaryButton { get; set; }
    [Parameter] public EventCallback OnPrimaryClick { get; set; }
    [Parameter] public EventCallback OnSecondaryClick { get; set; }
}

@if(IsVisible is true)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center">
        <div class="absolute inset-0 bg-black/60"></div>
        <div class="relative w-11/12 max-w-lg rounded-md bg-black p-6 text-white shadow-lg">
            <div class="mb-4">@ChildContent</div>
            <div class="flex justify-between">
                <button class="rounded border border-white px-4 py-2 text-white hover:bg-white/10" @onclick=@OnSecondaryClickedAsync>
                    @if(SecondaryButton is not null)
                    {
                        @SecondaryButton
                    }
                    else
                    {
                        <span>Cancel</span>
                    }
                </button>
                <button class="rounded bg-white px-4 py-2 text-black hover:opacity-90" @onclick=@OnPrimaryClickedAsync>
                    @if(PrimaryButton is not null)
                    {
                        @PrimaryButton
                    }
                    else
                    {
                        <span>OK</span>
                    }
                </button>
            </div>
        </div>
    </div>
}


@code
{
    private Task OnPrimaryClickedAsync()
    {
        return OnPrimaryClick.InvokeAsync(null);
    }
    private Task OnSecondaryClickedAsync()
    {
        return OnSecondaryClick.InvokeAsync(null);
    }
}